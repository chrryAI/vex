{
  "name": "@chrryai/chrry",
  "version": "2.1.77",
  "description": "A modern, cross-platform UI library for React, React Native, and Next.js",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./Chrry": "./Chrry.tsx",
    "./globals.scss": "./globals.scss",
    "./utils": "./utils/index.ts",
    "./utils/*": "./utils/*.ts",
    "./types": "./types/index.ts",
    "./types/*": "./types/*.ts",
    "./locales": "./locales.ts",
    "./locales/*": "./locales/*.json",
    "./schemas/*": "./schemas/*.ts",
    "./hooks": "./hooks/index.ts",
    "./hooks/*": "./hooks/*.ts",
    "./context": "./context/index.ts",
    "./context/*": "./context/*.ts",
    "./context/providers": "./context/providers/index.ts",
    "./context/providers/*": "./context/providers/*.tsx",
    "./lib": "./lib/index.ts",
    "./lib/*": "./lib/*.ts",
    "./package.json": "./package.json",
    "./*": "./*"
  },
  "files": ["dist", "locales", "**/*.css", "**/*.scss", "README.md"],
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/chrryai/chrry.git"
  },
  "keywords": [
    "react",
    "react-native",
    "nextjs",
    "ui",
    "components",
    "cross-platform",
    "typescript"
  ],
  "author": "Iliyan Velinov",
  "license": "AGPL-3.0",
  "bugs": {
    "url": "https://github.com/chrryai/chrry/issues"
  },
  "homepage": "https://chrry.dev",
  "scripts": {
    "build": "pnpm exec tsup",
    "dev": "pnpm exec tsup --watch",
    "lint": "biome check .",
    "generate:component": "turbo gen react-component",
    "check-types": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "pnpm exec vitest run",
    "test:coverage": "pnpm exec vitest run --coverage && node -e \"const fs=require('fs');const p='coverage/lcov.info';if(fs.existsSync(p)){const c=fs.readFileSync(p,'utf8');const lines=c.split('\\n');const newLines=lines.map(l=>{if(l.startsWith('SF:')){let f=l.substring(3);if(f.includes('packages/ui/')){return 'SF:'+f.substring(f.indexOf('packages/ui/'));}return 'SF:packages/ui/'+f;}return l;});fs.writeFileSync(p,newLines.join('\\n'));}\""
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^8.1.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.2.2",
    "@lobehub/icons": "^5.0.1",
    "@number-flow/react": "^0.6.0",
    "@piotr-cz/swr-idb-cache": "^1.1.2",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@sentry/react": "^10.45.0",
    "@stripe/stripe-js": "^8.11.0",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@types/chrome": "^0.1.38",
    "@types/nprogress": "^0.2.3",
    "@types/react": "19.2.14",
    "@types/react-big-calendar": "^1.16.3",
    "@types/react-dom": "19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/sanitize-html": "^2.16.1",
    "@types/three": "^0.183.1",
    "@types/uuid": "^11.0.0",
    "@uidotdev/usehooks": "^2.4.1",
    "ai": "^6.0.134",
    "antd": "^6.3.3",
    "clsx": "^2.1.1",
    "dexie": "^4.3.0",
    "dnd-core": "^16.0.1",
    "emoji-picker-react": "^4.18.0",
    "expo-keep-awake": "^55.0.4",
    "firebase": "^12.11.0",
    "framer-motion": "^12.38.0",
    "i18n-iso-countries": "^7.14.0",
    "i18next": "^25.10.4",
    "idb": "^8.0.3",
    "javascript-time-ago": "^2.6.4",
    "jwt-decode": "^4.0.0",
    "lucide-react": "^0.577.0",
    "lucide-react-native": "^0.577.0",
    "markdown-to-jsx": "^9.7.13",
    "moti": "^0.30.0",
    "motion": "^12.38.0",
    "next-auth": "^4.24.13",
    "nextjs-toploader": "^3.9.17",
    "nprogress": "^0.2.0",
    "p-limit": "^7.3.0",
    "react": "^19.2.4",
    "react-audio-play": "^1.0.4",
    "react-circle-flags": "^0.0.27",
    "react-dnd": "^16.0.1",
    "react-dnd-html5-backend": "^16.0.1",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.72.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^16.6.1",
    "react-icons": "^5.6.0",
    "react-intersection-observer": "^10.0.3",
    "react-markdown": "^10.1.0",
    "react-native-draglist": "^3.10.0",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-mmkv": "^4.3.0",
    "react-native-reanimated": "4.2.3",
    "react-native-toast-message": "^2.3.3",
    "react-select": "^5.10.2",
    "react-syntax-highlighter": "^16.1.1",
    "react-use-promise": "^0.5.0",
    "remark-gfm": "^4.0.1",
    "rn-emoji-keyboard": "^1.7.0",
    "sanitize-html": "^2.17.2",
    "sass": "^1.98.0",
    "superjson": "^2.2.6",
    "swr": "^2.4.1",
    "three": "^0.183.2",
    "use-debounce": "^10.1.0",
    "usehooks-ts": "^3.1.1",
    "uuid": "^13.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@react-navigation/native": "^7.1.34",
    "@react-navigation/native-stack": "^7.14.6",
    "@repo/typescript-config": "workspace:*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react-native": "^0.73.0",
    "@vitest/coverage-istanbul": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.1.0",
    "happy-dom": "^20.8.4",
    "react-native": "0.84.1",
    "react-native-svg": "^15.15.4",
    "tsup": "^8.5.1",
    "typescript": "5.9.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0",
    "react-native": "*",
    "react-native-svg": "*"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "optionalDependencies": {
    "date-fns": "^4.1.0",
    "react-big-calendar": "^1.19.4",
    "recharts": "^3.8.0"
  }
}
