{
  "name": "@chrryai/sushi-cli-v2",
  "version": "2.0.0",
  "description": "🍣 SUSHI CLI v2 - Spatial AI Development Assistant (Claude Code killer)",
  "keywords": [
    "ai",
    "claude-code-alternative",
    "cli",
    "coding-assistant",
    "mcp",
    "multi-modal",
    "mutation-testing",
    "spatial-navigation",
    "terminal"
  ],
  "license": "AGPL-3.0",
  "author": "Iliyan Velinov <chrry.ai>",
  "bin": {
    "sushi": "./dist/index.js",
    "sushi2": "./dist/index.js"
  },
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.tsx",
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "pkg": "pkg . --out-path=binaries",
    "test": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.0.4",
    "ai": "^4.0.0",
    "chalk": "^5.4.0",
    "clipboardy": "^4.0.0",
    "diff": "^7.0.0",
    "falkordb": "^6.6.0",
    "figures": "^6.1.0",
    "ink": "^6.x",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^3.0.0",
    "ink-link": "^4.x",
    "ink-select-input": "^6.x",
    "ink-spinner": "^5.x",
    "ink-text-input": "^6.x",
    "openai": "^4.90.0",
    "react": "^19.x",
    "simple-git": "^3.27.0",
    "strip-ansi": "^7.1.0",
    "ws": "^8.18.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.0",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^22.10.0",
    "@types/react": "^19.x",
    "@types/ws": "^8.5.13",
    "pkg": "^5.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pkg": {
    "scripts": [
      "dist/**/*.js"
    ],
    "assets": [
      "node_modules/ink/**/*"
    ],
    "targets": [
      "node20-linux-x64",
      "node20-macos-x64",
      "node20-macos-arm64",
      "node20-win-x64"
    ]
  }
}
