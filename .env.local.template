# ============================================
# VEX LOCAL DEVELOPMENT ENVIRONMENT
# ============================================
# This file contains default values for running Vex entirely locally
# Copy this to .env.local and customize as needed

# ============================================
# LOCAL INFRASTRUCTURE (Docker Containers)
# ============================================

# PostgreSQL
DATABASE_URL=postgresql://vex:vex_local_dev@localhost:5432/vex
POSTGRES_USER=vex
POSTGRES_PASSWORD=vex_local_dev
POSTGRES_DB=vex

# Redis
REDIS_URL=redis://:vex_redis_local@localhost:6379
REDIS_PASSWORD=vex_redis_local

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ROOT_USER=vex
MINIO_ROOT_PASSWORD=vex_minio_local_password
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET_NAME=chrry-chat-files
S3_BUCKET_NAME_APPS=chrry-app-profiles
S3_ACCESS_KEY_ID=vex
S3_SECRET_ACCESS_KEY=vex_minio_local_password
S3_PUBLIC_URL=http://localhost:9000

# FalkorDB (Knowledge Graph)
FALKORDB_URL=redis://localhost:6380
FALKORDB_GRAPH_NAME=vex_knowledge_graph

# Email (Mailhog - local SMTP mock)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
# Mailhog Web UI: http://localhost:8025

# ============================================
# APPLICATION SETTINGS
# ============================================

# Environment
NODE_ENV=development
VITE_NODE_ENV=development
VITE_TESTING_ENV=

# API URLs
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
WS_SERVER_URL=http://localhost:3001

# Site Mode (chrry, vex, tribe, etc.)
VITE_SITE_MODE=vex

# Auth
NEXTAUTH_SECRET=local_dev_secret_change_in_production
AUTH_TRUST_HOST=true

# ============================================
# USER API KEYS (BYOK - Bring Your Own Key)
# ============================================
# Add your own API keys here for AI services

# OpenAI
OPENAI_API_KEY=

# Anthropic (Claude)
ANTHROPIC_API_KEY=
CLAUDE_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Google (Gemini)
GEMINI_API_KEY=

# Perplexity
PERPLEXITY_API_KEY=

# Replicate
REPLICATE_API_KEY=

# OpenRouter (single key for multiple models)
OPENROUTER_API_KEY=

# ============================================
# OPTIONAL: CLOUD SYNC (Premium Features)
# ============================================
# Set to true to enable cloud sync with Hetzner
CLOUD_SYNC_ENABLED=false

# If cloud sync is enabled, add these:
# CLOUD_API_URL=https://api.chrry.ai
# CLOUD_API_KEY=

# Stripe (only needed for cloud sync/premium)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PUBLISHABLE_KEY=
# STRIPE_PRICE_CREDITS_ID=
# STRIPE_PRICE_PLUS_ID=
# STRIPE_PRICE_PRO_ID=

# ============================================
# OPTIONAL: EXTERNAL SERVICES
# ============================================

# Google OAuth (optional - local mode uses email/password)
# GOOGLE_WEB_CLIENT_ID=
# GOOGLE_WEB_CLIENT_SECRET=

# Apple Sign-In (optional)
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=

# Sentry (error tracking)
# SENTRY_DSN=
# VITE_SENTRY_DSN=

# Analytics
# VITE_PLAUSIBLE_DOMAIN=

# Weather API
# WEATHER_API_KEY=

# MaxMind GeoIP
# MAXMIND_ACCOUNT_ID=
# MAXMIND_LICENSE_KEY=

# Malware Scanner
# MALWARE_SCANNER_API_KEY=
# MALWARE_SCANNER_URL=

# Web Push Notifications
# VAPID_PRIVATE_KEY=
# VITE_VAPID_PUBLIC_KEY=

# ============================================
# BLUESKY AUTO-POSTING (Optional)
# ============================================
# BLUESKY_HANDLE_CHRRY=
# BLUESKY_PASSWORD_CHRRY=
# BLUESKY_HANDLE_TRIBE=
# BLUESKY_PASSWORD_TRIBE=

