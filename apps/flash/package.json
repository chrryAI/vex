{
  "name": "flash",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "rm -rf .vite node_modules/.vite dist && NODE_ENV=development node server --force",
    "build": "pnpm run build:client && pnpm run build:server",
    "build:client": "NODE_ENV=production pnpm vite build --outDir dist/client",
    "build:server": "NODE_ENV=production pnpm vite build --ssr src/entry-server.tsx --outDir dist/server",
    "start": "cross-env NODE_ENV=production node server",
    "preview": "cross-env NODE_ENV=production node server",
    "check-types": "tsc --noEmit",
    "test": "vitest run --coverage.enabled --coverage.provider=v8 --coverage.reporter=text --coverage.reporter=lcov"
  },
  "dependencies": {
    "@arcjet/node": "1.3.0",
    "@chrryai/chrry": "workspace:*",
    "@sentry/node": "^10.45.0",
    "@vitejs/plugin-react": "^6.0.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.1",
    "gray-matter": "^4.0.3",
    "i18n-iso-countries": "^7.14.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-helmet-async": "^3.0.0",
    "react-markdown": "^10.1.0",
    "react-native-web": "^0.19.13",
    "remark-gfm": "^4.0.1",
    "sirv": "^3.0.2",
    "uuid": "^13.0.0",
    "vite": "^8.0.1",
    "vite-plugin-compression2": "^2.5.3",
    "vite-plugin-static-copy": "^4.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.0",
    "cross-env": "^10.1.0",
    "sass": "^1.98.0",
    "typescript": "~5.9.3",
    "vitest": "^4.1.0"
  }
}
