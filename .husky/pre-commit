#!/usr/bin/env sh

# 🔒 Secret Scanning with Gitleaks
echo "🔍 Scanning for secrets..."
gitleaks protect --staged --redact --verbose --config=gitleaks.toml

if [ $? -ne 0 ]; then
  echo ""
  echo "❌ Gitleaks detected potential secrets in your staged files!"
  echo ""
  echo "🔧 To fix this:"
  echo "  1. Review the findings above"
  echo "  2. Remove the secret or add it to .gitignore"
  echo "  3. If it's a false positive, update gitleaks.toml allowlist"
  echo ""
  echo "⚠️  EMERGENCY BYPASS (use with caution):"
  echo "  SKIP=gitleaks git commit -m \"your message\""
  echo ""
  exit 1
fi

echo "✅ No secrets detected"

# 📦 Large File Check (GitHub limit: 100MB)
echo "📦 Checking for large files..."

# Find staged files larger than 50MB (using git cat-file for binary files too)
LARGE_FILES=$(
  git diff --cached --name-only | while read file; do
    if [ -f "$file" ]; then
      SIZE=$(git cat-file -s :"$file" 2>/dev/null || stat -f%z "$file" 2>/dev/null || stat -c%s "$file" 2>/dev/null || echo 0)
      if [ "$SIZE" -gt 52428800 ]; then
        echo "$file ($((SIZE / 1024 / 1024))MB)"
      fi
    fi
  done
)

if [ -n "$LARGE_FILES" ]; then
  echo ""
  echo "❌ Large files detected (>50MB):"
  echo "$LARGE_FILES"
  echo ""
  echo "GitHub has a 100MB file size limit."
  echo "Please remove these files from staging:"
  echo "  git reset HEAD <file>"
  echo ""
  echo "If these files are needed, consider:"
  echo "  - Git LFS: https://git-lfs.github.com"
  echo "  - Storing in external storage (S3, etc.)"
  echo ""
  exit 1
fi

echo "✅ No large files detected"

# Run existing SCSS tests
pnpm run test:scss
